APP_ENV=production
APP_DEBUG=false

# Main application database. Keep Supabase/PostgreSQL here for business data.
DB_CONNECTION=pgsql
DB_HOST=your-postgres-host
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=your-postgres-user
DB_PASSWORD=your-postgres-password
DB_SSLMODE=require

# Production runtime stores. Do not use the remote SQL database for these.
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_STORE=redis
QUEUE_CONNECTION=redis

# Use predis when the deployment platform does not provide the phpredis extension.
REDIS_CLIENT=predis
REDIS_URL=rediss://default:your-redis-password@your-redis-host:6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90

# Recommended for HTTPS production deployments.
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CHATBOT_ENABLED=true
CHATBOT_PROVIDER_ORDER=gemini,groq,openrouter
CHATBOT_CACHE_DRIVER=database
CHATBOT_CACHE_TTL_SECONDS=86400
CHATBOT_VECTOR_ENABLED=false
CHATBOT_VECTOR_MIN_SIMILARITY=0.68
CHATBOT_VECTOR_CANDIDATE_LIMIT=80
CHATBOT_VECTOR_CONTEXT_LIMIT=5
CHATBOT_EMBEDDING_PROVIDER_ORDER=gemini,openai
CHATBOT_EMBEDDING_MAX_INPUT_CHARS=6000
CHATBOT_EMBEDDING_TIMEOUT_SECONDS=30
CHATBOT_MAX_CONTEXT_ITEMS=5
CHATBOT_MAX_TOKENS=700
CHATBOT_TEMPERATURE=0.3
CHATBOT_TIMEOUT_SECONDS=25
CHATBOT_MAX_RETRIES=8
AI_FAILOVER_STATUS_CODES=429,500,502,503,504
AI_KEY_COOLDOWN_SECONDS=3600
GEMINI_API_KEYS=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GROQ_API_KEYS=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEYS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://danangtrip-web.duytayqt.workers.dev
OPENROUTER_APP_NAME=DanangTrip
OPENAI_API_KEYS=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
CHATBOT_GUEST_DAILY_LIMIT=10
CHATBOT_USER_DAILY_LIMIT=30
CHATBOT_ADMIN_DAILY_LIMIT=100
