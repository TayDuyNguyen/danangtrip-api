APP_ENV=production
APP_DEBUG=false

# Main application database. Keep Supabase/PostgreSQL here for business data.
DB_CONNECTION=pgsql
DB_HOST=your-postgres-host
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=your-postgres-user
DB_PASSWORD=your-postgres-password
DB_SSLMODE=require

# Production runtime stores. Do not use the remote SQL database for these.
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_STORE=redis
QUEUE_CONNECTION=redis

# Use predis when the deployment platform does not provide the phpredis extension.
REDIS_CLIENT=predis
REDIS_URL=rediss://default:your-redis-password@your-redis-host:6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90

# Recommended for HTTPS production deployments.
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
